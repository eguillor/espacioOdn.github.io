---
import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  cardTitleModal: string;
  cardPreg1: string;
  cardRes1: string;
  cardPreg2: string;
  cardRes2: string;
  cardPreg3: string;
  cardRes3: string;
  cardPreg4: string;
  cardRes4: string;
}

const {
  id,
  cardTitleModal,
  cardPreg1,
  cardRes1,
  cardPreg2,
  cardRes2,
  cardPreg3,
  cardRes3,
  cardPreg4,
  cardRes4,
} = Astro.props;
---

<!-- Modal -->
<div
  class="modal fade"
  id={id}
  data-bs-backdrop="static"
  data-bs-keyboard="false"
  tabindex="-1"
  aria-labelledby="staticBackdropLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header text-center">
        <h3 class="text-primary">{cardTitleModal}</h3>
        <button
          type="button"
          class="btn-close d-inline-flex focus-ring focus-ring-secondary p-2 text-decoration-none border rounded-2"
          data-bs-dismiss="modal"
          aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="accordion shadow-sm" id={id}>
          <div class="accordion-item">
            <h5 class="accordion-header">
              <button
                class="accordion-button"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseOne"
                aria-expanded="true"
                aria-controls="collapseOne"
              >
                {cardPreg1}
              </button>
            </h5>
            <div
              id="collapseOne"
              class="accordion-collapse collapse show"
              data-bs-parent={`#${id}`}
            >
              <div class="accordion-body">
                {cardRes1}
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h5 class="accordion-header">
              <button
                class="accordion-button collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseTwo"
                aria-expanded="false"
                aria-controls="collapseTwo"
              >
                {cardPreg2}
              </button>
            </h5>
            <div
              id="collapseTwo"
              class="accordion-collapse collapse"
              data-bs-parent={`#${id}`}
            >
              <div class="accordion-body">
                {cardRes2}
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h5 class="accordion-header">
              <button
                class="accordion-button collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseThree"
                aria-expanded="false"
                aria-controls="collapseThree"
              >
                {cardPreg3}
              </button>
            </h5>
            <div
              id="collapseThree"
              class="accordion-collapse collapse"
              data-bs-parent={`#${id}`}
            >
              <div class="accordion-body">
                {cardRes3}
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h5 class="accordion-header">
              <button
                class="accordion-button collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseFour"
                aria-expanded="false"
                aria-controls="collapseFour"
              >
                {cardPreg4}
              </button>
            </h5>
            <div
              id="collapseFour"
              class="accordion-collapse collapse"
              data-bs-parent={`#${id}`}
            >
              <div class="accordion-body">
                {cardRes4}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <div class="d-grid gap-2 col-12 col-lg-4 mx-auto">
          <a
            href="https://wa.me/5490889612468"
            target="_blank"
            class="btn btn-primary">QUIERO SABER MÁS</a
          >
        </div>
      </div>
    </div>
  </div>
</div>
